# Mapbox (required)
VITE_MAPBOX_TOKEN=

# Home location (defaults to Brookline if not set)
VITE_HOME_LAT=42.3467
VITE_HOME_LNG=-71.1304

# MBTA API key (optional, recommended for higher rate limits)
# Get one at https://api-v3.mbta.com
VITE_MBTA_API_KEY=

# Slack Incoming Webhook (server-side only, not exposed to client)
# Set up at https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=
